# Copiá este archivo a .env y completá los valores reales.
#   cp .env.example .env

# --- Base de datos compartida (la misma que usa app.goberna.pe) ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306

# --- App principal (para redirect de login) ---
MAIN_APP_URL=https://app.goberna.pe

# --- Dev local ---
DEBUG=True
# Vacío en local: permite que el login/sesión funcione en 127.0.0.1
# (en prod queda .goberna.pe vía la env var de Vercel)
SESSION_COOKIE_DOMAIN=
